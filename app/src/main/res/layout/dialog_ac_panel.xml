<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_card"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="❄  空调控制"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dialog_ac_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="✕"
            android:textColor="@color/text_tertiary"
            android:textSize="16sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="12dp">

            <com.diui.launcher.ui.ArcTempView
                android:id="@+id/ac_arc_temp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:arcAspectRatio="0.75"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center">

                <TextView
                    android:id="@+id/ac_temp_down"
                    android:layout_width="44dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="−"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:background="@drawable/bg_switch_btn" />

                <View
                    android:layout_width="16dp"
                    android:layout_height="0dp" />

                <TextView
                    android:id="@+id/ac_temp_up"
                    android:layout_width="44dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:background="@drawable/bg_switch_btn" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="3"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="vertical"
            android:background="@color/bg_surface_variant"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="风向"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/ac_mode_face"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="↑ 吹脸"
                    android:textSize="12sp"
                    android:background="@drawable/bg_switch_btn"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="3dp" />

                <TextView
                    android:id="@+id/ac_mode_foot"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="↓ 吹脚"
                    android:textSize="12sp"
                    android:background="@drawable/bg_switch_btn"
                    android:layout_marginEnd="3dp" />

                <TextView
                    android:id="@+id/ac_mode_defrost"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="≋ 除霜"
                    android:textSize="12sp"
                    android:background="@drawable/bg_switch_btn" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="循环"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/ac_cycle_inner"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="↺ 内循环"
                    android:textSize="12sp"
                    android:background="@drawable/bg_switch_btn"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="3dp" />

                <TextView
                    android:id="@+id/ac_cycle_outer"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="↻ 外循环"
                    android:textSize="12sp"
                    android:background="@drawable/bg_switch_btn" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="模式"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/ac_ctrl_auto"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="A 自动"
                    android:textSize="12sp"
                    android:background="@drawable/bg_switch_btn"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="3dp" />

                <TextView
                    android:id="@+id/ac_ctrl_manual"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="M 手动"
                    android:textSize="12sp"
                    android:background="@drawable/bg_switch_btn" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="风量"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:minWidth="36dp" />

        <LinearLayout
            android:id="@+id/ac_wind_row"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/ac_wind_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3级"
            android:textColor="@color/accent"
            android:textSize="12sp"
            android:minWidth="28dp"
            android:gravity="end" />
    </LinearLayout>

    <TextView
        android:id="@+id/ac_toggle_btn"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center"
        android:text="❄  已开启"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/bg_switch_btn" />
</LinearLayout>
