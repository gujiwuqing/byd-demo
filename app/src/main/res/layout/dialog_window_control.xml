<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- 标题 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🪟 车窗控制"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/win_close_dialog"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="✕"
            android:textColor="@color/text_tertiary"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- 车窗布局：2x2 网格 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp">

        <!-- 前排 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <!-- 左前车窗 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@color/bg_surface_variant"
                android:padding="12dp"
                android:layout_marginEnd="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="左前"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:id="@+id/win_fl_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已关闭"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView android:id="@+id/win_fl_open" android:layout_width="0dp" android:layout_weight="1" android:layout_height="30dp" android:background="@drawable/bg_switch_btn" android:gravity="center" android:text="全开" android:textColor="@color/text_primary" android:textSize="11sp" android:layout_marginEnd="3dp" />
                    <TextView android:id="@+id/win_fl_half" android:layout_width="0dp" android:layout_weight="1" android:layout_height="30dp" android:background="@drawable/bg_switch_btn" android:gravity="center" android:text="半开" android:textColor="@color/text_primary" android:textSize="11sp" android:layout_marginEnd="3dp" />
                    <TextView android:id="@+id/win_fl_close" android:layout_width="0dp" android:layout_weight="1" android:layout_height="30dp" android:background="@drawable/bg_switch_btn" android:gravity="center" android:text="关闭" android:textColor="@color/accent" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 右前车窗 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@color/bg_surface_variant"
                android:padding="12dp"
                android:layout_marginStart="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="右前"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:id="@+id/win_fr_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已关闭"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView android:id="@+id/win_fr_open" android:layout_width="0dp" android:layout_weight="1" android:layout_height="30dp" android:background="@drawable/bg_switch_btn" android:gravity="center" android:text="全开" android:textColor="@color/text_primary" android:textSize="11sp" android:layout_marginEnd="3dp" />
                    <TextView android:id="@+id/win_fr_half" android:layout_width="0dp" android:layout_weight="1" android:layout_height="30dp" android:background="@drawable/bg_switch_btn" android:gravity="center" android:text="半开" android:textColor="@color/text_primary" android:textSize="11sp" android:layout_marginEnd="3dp" />
                    <TextView android:id="@+id/win_fr_close" android:layout_width="0dp" android:layout_weight="1" android:layout_height="30dp" android:background="@drawable/bg_switch_btn" android:gravity="center" android:text="关闭" android:textColor="@color/accent" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 后排 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- 左后车窗 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@color/bg_surface_variant"
                android:padding="12dp"
                android:layout_marginEnd="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="左后"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:id="@+id/win_rl_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已关闭"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView android:id="@+id/win_rl_open" android:layout_width="0dp" android:layout_weight="1" android:layout_height="30dp" android:background="@drawable/bg_switch_btn" android:gravity="center" android:text="全开" android:textColor="@color/text_primary" android:textSize="11sp" android:layout_marginEnd="3dp" />
                    <TextView android:id="@+id/win_rl_half" android:layout_width="0dp" android:layout_weight="1" android:layout_height="30dp" android:background="@drawable/bg_switch_btn" android:gravity="center" android:text="半开" android:textColor="@color/text_primary" android:textSize="11sp" android:layout_marginEnd="3dp" />
                    <TextView android:id="@+id/win_rl_close" android:layout_width="0dp" android:layout_weight="1" android:layout_height="30dp" android:background="@drawable/bg_switch_btn" android:gravity="center" android:text="关闭" android:textColor="@color/accent" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 右后车窗 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@color/bg_surface_variant"
                android:padding="12dp"
                android:layout_marginStart="6dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="右后"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:id="@+id/win_rr_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已关闭"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView android:id="@+id/win_rr_open" android:layout_width="0dp" android:layout_weight="1" android:layout_height="30dp" android:background="@drawable/bg_switch_btn" android:gravity="center" android:text="全开" android:textColor="@color/text_primary" android:textSize="11sp" android:layout_marginEnd="3dp" />
                    <TextView android:id="@+id/win_rr_half" android:layout_width="0dp" android:layout_weight="1" android:layout_height="30dp" android:background="@drawable/bg_switch_btn" android:gravity="center" android:text="半开" android:textColor="@color/text_primary" android:textSize="11sp" android:layout_marginEnd="3dp" />
                    <TextView android:id="@+id/win_rr_close" android:layout_width="0dp" android:layout_weight="1" android:layout_height="30dp" android:background="@drawable/bg_switch_btn" android:gravity="center" android:text="关闭" android:textColor="@color/accent" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 整体控制 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center">

        <TextView
            android:id="@+id/win_all_open"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:background="@drawable/bg_switch_btn"
            android:gravity="center"
            android:text="全部开启"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/win_all_half"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:background="@drawable/bg_switch_btn"
            android:gravity="center"
            android:text="全部半开"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/win_all_close"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:background="@drawable/bg_ac_btn"
            android:gravity="center"
            android:text="全部关闭"
            android:textColor="@color/accent"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
