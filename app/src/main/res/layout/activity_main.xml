<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_ambient_glass">

    <!-- 主内容：顶部栏 + 内容区 + 底部栏 -->
    <LinearLayout
        android:id="@+id/standard_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <include
            layout="@layout/view_top_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/top_bar_height" />

        <FrameLayout
            android:id="@+id/content_frame"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <include layout="@layout/page_status" />
            <include layout="@layout/page_controls" />
            <include layout="@layout/page_apps" />
            <include layout="@layout/page_settings" />
        </FrameLayout>

        <include
            layout="@layout/view_nav_bar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/nav_bar_height" />
    </LinearLayout>

    <!-- 无界模式（默认隐藏） -->
    <include layout="@layout/page_unbounded" />

    <!-- 全屏遮罩层（所有弹窗共用） -->
    <View
        android:id="@+id/overlay_mask"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone" />

    <!-- 车窗控制面板 -->
    <include
        layout="@layout/panel_window_control"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- 座椅控制面板 -->
    <include
        layout="@layout/panel_seat_control"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</FrameLayout>
