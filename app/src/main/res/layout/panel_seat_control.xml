<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/panel_seat"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_panel"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- 标题行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="座椅控制"
            android:drawableStart="@drawable/ic_seat"
            android:drawableTint="@color/accent"
            android:drawablePadding="8dp"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center_vertical" />
        <TextView
            android:id="@+id/seat_close_dialog"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="✕"
            android:textColor="@color/text_tertiary"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- 主副驾左右布局 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- 主驾 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="12dp">

            <!-- 主驾标题 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🧑"
                    android:textSize="22sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="主驾"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- 主驾通风 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_surface_variant"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌬"
                        android:textSize="18sp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="通风"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginStart="8dp" />
                    <TextView
                        android:id="@+id/seat_driver_vent_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="已关闭"
                        android:textColor="@color/text_tertiary"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:id="@+id/seat_driver_vent_off"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_seat_btn_selected"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layout_marginEnd="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="关" android:textColor="@color/accent" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/seat_driver_vent_1"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_seat_btn"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layout_marginEnd="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1" android:textColor="@color/text_secondary" android:textSize="18sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="低" android:textColor="@color/text_tertiary" android:textSize="10sp" />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/seat_driver_vent_2"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_seat_btn"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2" android:textColor="@color/text_secondary" android:textSize="18sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="高" android:textColor="@color/text_tertiary" android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 主驾加热 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_surface_variant"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥"
                        android:textSize="18sp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="加热"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginStart="8dp" />
                    <TextView
                        android:id="@+id/seat_driver_heat_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="已关闭"
                        android:textColor="@color/text_tertiary"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:id="@+id/seat_driver_heat_off"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_seat_btn_selected"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layout_marginEnd="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="关" android:textColor="@color/accent" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/seat_driver_heat_1"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_seat_btn"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layout_marginEnd="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1" android:textColor="@color/text_secondary" android:textSize="18sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="暖" android:textColor="@color/text_tertiary" android:textSize="10sp" />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/seat_driver_heat_2"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_seat_btn"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2" android:textColor="@color/text_secondary" android:textSize="18sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="热" android:textColor="@color/text_tertiary" android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/border"
            android:layout_marginEnd="12dp" />

        <!-- 副驾 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- 副驾标题 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤"
                    android:textSize="22sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="副驾"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- 副驾通风 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_surface_variant"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌬"
                        android:textSize="18sp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="通风"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginStart="8dp" />
                    <TextView
                        android:id="@+id/seat_pass_vent_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="已关闭"
                        android:textColor="@color/text_tertiary"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:id="@+id/seat_pass_vent_off"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_seat_btn_selected"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layout_marginEnd="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="关" android:textColor="@color/accent" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/seat_pass_vent_1"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_seat_btn"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layout_marginEnd="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1" android:textColor="@color/text_secondary" android:textSize="18sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="低" android:textColor="@color/text_tertiary" android:textSize="10sp" />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/seat_pass_vent_2"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_seat_btn"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2" android:textColor="@color/text_secondary" android:textSize="18sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="高" android:textColor="@color/text_tertiary" android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 副驾加热 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_surface_variant"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥"
                        android:textSize="18sp" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="加热"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginStart="8dp" />
                    <TextView
                        android:id="@+id/seat_pass_heat_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="已关闭"
                        android:textColor="@color/text_tertiary"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:id="@+id/seat_pass_heat_off"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_seat_btn_selected"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layout_marginEnd="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="关" android:textColor="@color/accent" android:textSize="13sp" android:textStyle="bold" />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/seat_pass_heat_1"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_seat_btn"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:layout_marginEnd="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1" android:textColor="@color/text_secondary" android:textSize="18sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="暖" android:textColor="@color/text_tertiary" android:textSize="10sp" />
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/seat_pass_heat_2"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_seat_btn"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2" android:textColor="@color/text_secondary" android:textSize="18sp" android:textStyle="bold" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="热" android:textColor="@color/text_tertiary" android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
