<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/panel_window"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_panel"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- 标题栏（固定） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="车窗控制"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginEnd="12dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="车窗锁定"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginEnd="8dp" />
            <TextView
                android:id="@+id/win_lock_switch"
                android:layout_width="44dp"
                android:layout_height="24dp"
                android:background="@drawable/bg_settings_switch_track_off"
                android:gravity="center" />
        </LinearLayout>

        <TextView
            android:id="@+id/win_close_dialog"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="X"
            android:textColor="@color/text_tertiary"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- 可滚动内容区 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fadingEdge="vertical"
        android:fadingEdgeLength="12dp"
        android:requiresFadingEdge="vertical"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 三栏布局：左车窗列 | 车辆图 | 右车窗列 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">

                <!-- 左列：左前 + 左后 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- 左前车窗 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/bg_surface_variant"
                        android:padding="10dp"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="左前车窗"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:layout_marginBottom="4dp" />
                        <TextView
                            android:id="@+id/win_fl_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="已关闭"
                            android:textColor="@color/status_good"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:id="@+id/win_fl_up"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_switch_btn"
                                android:gravity="center"
                                android:text="▲ 升"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:layout_marginEnd="4dp" />
                            <TextView
                                android:id="@+id/win_fl_down"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_switch_btn"
                                android:gravity="center"
                                android:text="▼ 降"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 左后车窗 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/bg_surface_variant"
                        android:padding="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="左后车窗"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:layout_marginBottom="4dp" />
                        <TextView
                            android:id="@+id/win_rl_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="已关闭"
                            android:textColor="@color/status_good"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:id="@+id/win_rl_up"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_switch_btn"
                                android:gravity="center"
                                android:text="▲ 升"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:layout_marginEnd="4dp" />
                            <TextView
                                android:id="@+id/win_rl_down"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_switch_btn"
                                android:gravity="center"
                                android:text="▼ 降"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- 中间：车辆示意图 -->
                <com.diui.launcher.ui.VehicleDiagramView
                    android:id="@+id/win_vehicle_diagram"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:minHeight="160dp" />

                <!-- 右列：右前 + 右后 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- 右前车窗 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/bg_surface_variant"
                        android:padding="10dp"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="右前车窗"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:layout_marginBottom="4dp" />
                        <TextView
                            android:id="@+id/win_fr_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="已关闭"
                            android:textColor="@color/status_good"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:id="@+id/win_fr_up"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_switch_btn"
                                android:gravity="center"
                                android:text="▲ 升"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:layout_marginEnd="4dp" />
                            <TextView
                                android:id="@+id/win_fr_down"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_switch_btn"
                                android:gravity="center"
                                android:text="▼ 降"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 右后车窗 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@color/bg_surface_variant"
                        android:padding="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="右后车窗"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:layout_marginBottom="4dp" />
                        <TextView
                            android:id="@+id/win_rr_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="已关闭"
                            android:textColor="@color/status_good"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:id="@+id/win_rr_up"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_switch_btn"
                                android:gravity="center"
                                android:text="▲ 升"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp"
                                android:layout_marginEnd="4dp" />
                            <TextView
                                android:id="@+id/win_rr_down"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="34dp"
                                android:background="@drawable/bg_switch_btn"
                                android:gravity="center"
                                android:text="▼ 降"
                                android:textColor="@color/text_primary"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 后备箱 + 引擎盖 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <!-- 后备箱 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:background="@color/bg_surface_variant"
                    android:padding="10dp"
                    android:layout_marginEnd="6dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="后备箱"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/win_trunk_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="已关闭"
                        android:textColor="@color/status_good"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:id="@+id/win_trunk_toggle"
                        android:layout_width="56dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_switch_btn"
                        android:gravity="center"
                        android:text="打开"
                        android:textColor="@color/accent"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- 引擎盖 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:background="@color/bg_surface_variant"
                    android:padding="10dp"
                    android:layout_marginStart="6dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="引擎盖"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/win_hood_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="已关闭"
                        android:textColor="@color/status_good"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp" />
                    <TextView
                        android:id="@+id/win_hood_toggle"
                        android:layout_width="56dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_switch_btn"
                        android:gravity="center"
                        android:text="打开"
                        android:textColor="@color/accent"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 全局控制（固定底部） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center">
        <TextView
            android:id="@+id/win_all_open"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:background="@drawable/bg_switch_btn"
            android:gravity="center"
            android:text="全部开启"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />
        <TextView
            android:id="@+id/win_all_close"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="40dp"
            android:background="@drawable/bg_ac_btn"
            android:gravity="center"
            android:text="全部关闭"
            android:textColor="@color/accent"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
